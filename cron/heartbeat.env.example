# Heartbeat ping config for bin/cron-run.sh.
#
# Copy to cron/heartbeat.env (gitignored) ON THE SERVER and fill in. When this
# file is absent, cron-run.sh skips pinging entirely — so local/dev checkouts
# need no config and the cron jobs behave exactly as before.

# Base URL of the deployed cta-heartbeat Worker (no trailing slash).
HB_PING_URL=https://cta-heartbeat.<your-subdomain>.workers.dev

# Must match the PING_TOKEN secret set on the Worker (wrangler secret put PING_TOKEN).
HB_PING_TOKEN=replace-with-the-ping-token
