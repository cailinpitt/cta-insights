{
  "name": "cta-bot",
  "version": "0.0.1",
  "description": "Bluesky bot that posts visualizations from CTA train and bus tracker APIs",
  "main": "index.js",
  "dependencies": {
    "@atproto/api": "^0.18.16",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^8.1.0",
    "lodash": "^4.18.1",
    "minimist": "^1.2.3",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "bunching": "node bin/bunching.js",
    "bunching:dry": "node bin/bunching.js --dry-run",
    "gaps": "node bin/gaps.js",
    "gaps:dry": "node bin/gaps.js --dry-run",
    "fetch-gtfs": "node scripts/fetch-gtfs.js",
    "fetch-signals": "node scripts/fetch-signals.js",
    "speedmap": "node bin/speedmap.js",
    "speedmap:dry": "node bin/speedmap.js --dry-run",
    "train-snapshot": "node bin/trainSnapshot.js",
    "train-snapshot:dry": "node bin/trainSnapshot.js --dry-run",
    "train-bunching": "node bin/trainBunching.js",
    "train-bunching:dry": "node bin/trainBunching.js --dry-run",
    "train-gaps": "node bin/trainGaps.js",
    "train-gaps:dry": "node bin/trainGaps.js --dry-run",
    "train-speedmap": "node bin/trainSpeedmap.js",
    "train-speedmap:dry": "node bin/trainSpeedmap.js --dry-run",
    "observe-ghosts": "node scripts/observeGhosts.js",
    "ghosts": "node bin/ghosts.js",
    "ghosts:dry": "node bin/ghosts.js --dry-run",
    "train-ghosts": "node bin/trainGhosts.js",
    "train-ghosts:dry": "node bin/trainGhosts.js --dry-run",
    "test": "node --test test/*.test.js"
  },
  "author": "Cailin Pitt <cailinpitt1@gmail.com> (https://cailinpitt.com)",
  "license": "ISC"
}
